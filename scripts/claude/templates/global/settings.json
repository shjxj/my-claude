{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "sk-your-api-key",
    "ANTHROPIC_BASE_URL": "https://api.anthropic.com",
    "API_TIMEOUT_MS": "300000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },

  "theme": "dark",

  "permissions": {
    "defaultMode": "acceptEdits",

    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(node:*)",
      "Bash(mvn:*)",
      "Bash(gradle:*)",
      "Bash(java:*)",
      "Bash(go:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(flutter:*)",
      "Bash(dart:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(curl:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(ps:*)",
      "Bash(kill:*)",
      "Bash(pod:*)",
      "Bash(xcodebuild:*)",
      "Bash(kubectl:get*)",
      "Bash(kubectl:logs*)",
      "Bash(kubectl:describe*)",
      "Bash(redis-cli:*)",
      "Bash(mysql:*)",
      "Bash(psql:*)",
      "WebSearch",
      "WebFetch"
    ],

    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(> /dev/sda:*)",
      "Bash(curl * | sh:*)",
      "Bash(wget * | bash:*)",
      "Bash(kubectl:delete*)",
      "Bash(kubectl:apply*)",
      "Bash(docker:rm*)",
      "Bash(docker:prune*)",
      "Bash(mysql:*DROP*)",
      "Bash(mysql:*TRUNCATE*)",
      "Bash(psql:*DROP*)",
      "Bash(psql:*TRUNCATE*)",
      "Bash(git:push --force*)",
      "Bash(git:reset --hard*)",
      "Bash(git:clean*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/global-security.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/global-post-edit.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/global-session-start.sh\""
          }
        ]
      }
    ]
  },

  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "ecc@ecc": true,
    "spring-boot-dev@sivalabs-marketplace": true,
    "java-core@java-plugins": true,
    "java-spring@java-plugins": true,
    "java-quality@java-plugins": true,
    "planning-with-files@planning-with-files": true,
    "ralph-loop@claude-plugins-official": true
  }
}
